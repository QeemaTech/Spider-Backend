<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route all requests through Laravel's public directory when
    # document root is set to the project root.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    DirectoryIndex public/index.php
</IfModule>

Options -Indexes
